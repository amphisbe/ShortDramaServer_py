# 应用配置
APP_NAME=Short Drama FastAPI Server
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 数据库配置
# Demo 默认使用 SQLite，便于无 MySQL 环境直接运行；生产环境将 DB_DRIVER 改为 mysql 并配置 MySQL 参数。
DB_DRIVER=sqlite
SQLITE_DATABASE=./runtime/short_drama_demo.db

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=short_drama
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4
MYSQL_MAX_CONNECTIONS=32
MYSQL_STALE_TIMEOUT=300
